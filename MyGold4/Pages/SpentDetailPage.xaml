<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:MyGold4.PageModels"
             xmlns:models="clr-namespace:MyGold4.Models"
             xmlns:pages="clr-namespace:MyGold4.Pages"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             xmlns:controls="clr-namespace:MyGold4.Pages.Controls"
             xmlns:fonts="clr-namespace:Fonts"
             x:Class="MyGold4.Pages.SpentDetailPage"
             x:DataType="pageModels:SpentDetailPageModel"
             Title="Spent">

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Text="Delete"
            Command="{Binding DeleteCommand}"
            Order="Primary"
            Priority="0"
            IconImageSource="{StaticResource IconDelete}"
            SemanticProperties.Description="Delete Spent" />
    </ContentPage.ToolbarItems>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="{StaticResource LayoutPadding}" Spacing="{StaticResource LayoutSpacing}">

                <sf:SfTextInputLayout Hint="Date" >

                    <DatePicker
                        Date="{Binding Date}"
                        SemanticProperties.Description="Date"/>

                </sf:SfTextInputLayout>

                <sf:SfTextInputLayout
                     Hint="Category"
                     SemanticProperties.Description="ComboBox to Select Category"
                     SemanticProperties.Hint="State Collapsed">

                    <Picker SemanticProperties.Hint="Select the category for the spent"
                         ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding Category}"
                         SelectedIndex="{Binding CategoryIndex}"
                         SemanticProperties.Description="Category State Expanded"/>     

                </sf:SfTextInputLayout>

                <sf:SfTextInputLayout Hint="Name" >

                    <Entry
                        Text="{Binding Name}" 
                        SemanticProperties.Description="Name"
                        ReturnType="Next"
                        Keyboard="Text"/>

                </sf:SfTextInputLayout>

                <sf:SfTextInputLayout Hint="Value">
                    
                    <Entry
                        Text="{Binding Value}" 
                        Keyboard="Numeric"
                        SemanticProperties.Description="Value" 
                        ReturnType="Done"/>

                </sf:SfTextInputLayout>

                <Button Text="Save" 
                    MinimumHeightRequest="{OnIdiom 44, Desktop=60}"
                    Command="{Binding SaveCommand}" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>