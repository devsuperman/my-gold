<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:MyGold5.PageModels"
             xmlns:models="clr-namespace:MyGold5.Models"
             xmlns:controls="clr-namespace:MyGold5.Pages.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             x:Class="MyGold5.Pages.HomePage"
             x:DataType="pageModels:HomePageModel"
             x:Name="Page"
             Title="Home">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior                
                EventName="Appearing"                
                BindingContext="{Binding Path=BindingContext, Source={x:Reference Page}, x:DataType=ContentPage}"
                Command="{Binding Source={x:Reference Page}, Path=BindingContext.AppearingCommand, x:DataType=ContentPage}" />
    </ContentPage.Behaviors>

    <ContentPage.ToolbarItems>
        <ToolbarItem Order="Primary" IconImageSource="{StaticResource IconPreviousMenu}" Command="{Binding PreviousMonthCommand}"/>
        <ToolbarItem Order="Primary" IconImageSource="{StaticResource IconToday}" Command="{Binding ThisMonthCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid
        Padding="20"
        RowDefinitions="Auto, Auto, *">

        <Grid 
            Grid.Column="0"
            ColumnDefinitions="*,Auto"
            Margin="0,0,0,40">

            <Label 
                Style="{StaticResource Title1}"
                Text="{Binding Title}"/>

            <Label 
                HorizontalOptions="End"
                HorizontalTextAlignment="End"
                Text="{Binding Total, StringFormat='{0:C}'}" 
                Style="{StaticResource Title1}"
                TextColor="MediumSeaGreen"/>

        </Grid>

        <CollectionView 
            Grid.Row="1"
            ItemsSource="{Binding Totals}">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="20"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TotalByCategory">

                    <VerticalStackLayout 
                        Spacing="20"
                        Padding="20,0,20,0">

                        <Grid 
                            ColumnDefinitions="*,Auto"
                            VerticalOptions="Center">

                            <Label Text="{Binding Category}"/>

                            <Label 
                                Grid.Column="1"
                                Text="{Binding Total,StringFormat='{0:C}'}"
                                Style="{StaticResource Body1Strong}"/>

                        </Grid>

                        <BoxView
                            Color="{StaticResource Gray100}"
                            WidthRequest="400"
                            HeightRequest="1"/>

                    </VerticalStackLayout>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>