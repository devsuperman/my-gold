<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:MyGold5.PageModels"
             xmlns:models="clr-namespace:MyGold5.Models"
             xmlns:controls="clr-namespace:MyGold5.Pages.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             x:Class="MyGold5.Pages.HomePage"
             x:DataType="pageModels:HomePageModel"
             x:Name="Page"
             Title="Home">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior                
                EventName="Appearing"                
                BindingContext="{Binding Path=BindingContext, Source={x:Reference Page}, x:DataType=ContentPage}"
                Command="{Binding Source={x:Reference Page}, Path=BindingContext.AppearingCommand, x:DataType=ContentPage}" />
    </ContentPage.Behaviors>

    <Grid
        Padding="20"
        RowDefinitions="Auto, Auto, *">

        <Grid
            ColumnDefinitions="Auto,*,Auto"
            Margin="0,10,0,10">

            <Button
        Grid.Column="0"
        ImageSource="{StaticResource IconPrevious}"
        Command="{Binding PreviousMonthCommand}">
            </Button>

            <Label 
        Grid.Column="1"
        HorizontalTextAlignment="Center"
        Style="{StaticResource Title1}"
        Text="{Binding Title}"/>

            <Button
        Grid.Column="2"
        ImageSource="{StaticResource IconNext}"
        Command="{Binding NextMonthCommand}"/>

        </Grid>

        <CollectionView 
            Grid.Row="1"
            ItemsSource="{Binding Totals}">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="7.5"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TotalByCategory">
                    <Border 
                        Background="{AppThemeBinding Light={StaticResource LightSecondaryBackground},Dark={StaticResource DarkSecondaryBackground}}"
                        SemanticProperties.Description="{Binding Name, StringFormat='{0}'}">

                        <Grid ColumnDefinitions="*,Auto">

                            <Label 
                                Grid.Column="0"
                                Text="{Binding Category}"/>

                            <Label 
                                Grid.Column="1"
                                Text="{Binding Total, StringFormat='{0:C}'}" />
                        </Grid>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <StackLayout Padding="10" HorizontalOptions="End">
                    <Label 
                        Text="{Binding Total, StringFormat='{0:C}'}" 
                        Style="{StaticResource Title2}"/>   
                </StackLayout>
            </CollectionView.Footer>
            
        </CollectionView>

        <controls:AddButton
            Grid.Row="2"
            Command="{Binding AddCommand}"
            SemanticProperties.Description="Add" 
            ToolTipProperties.Text="Add" />
    </Grid>
</ContentPage>