<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:MyGold5.PageModels"
             xmlns:models="clr-namespace:MyGold5.Models"
             xmlns:controls="clr-namespace:MyGold5.Pages.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             x:Class="MyGold5.Pages.SpentListPage"
             x:Name="Page"
             x:DataType="pageModels:SpentListPageModel"
             Title="Expenses">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
                EventName="Appearing"                
                BindingContext="{Binding Path=BindingContext, Source={x:Reference Page}, x:DataType=ContentPage}"
                Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <ContentPage.ToolbarItems>
        <ToolbarItem Order="Primary" IconImageSource="{StaticResource IconFilter}" Command="{Binding FilterByCategoryCommand}" />
        <ToolbarItem Order="Primary" IconImageSource="{StaticResource IconPreviousMenu}" Command="{Binding PreviousMonthCommand}"/>
        <ToolbarItem Order="Primary" IconImageSource="{StaticResource IconToday}" Command="{Binding ThisMonthCommand}"/>
    </ContentPage.ToolbarItems>

    <Grid>

        <Grid RowDefinitions="Auto,*">

            <Grid 
                Padding="20"
                Grid.Column="0"
                ColumnDefinitions="*,Auto">

                <Label 
                    Style="{StaticResource Title1}"
                    Text="{Binding Title}"/>

                <Label 
                    HorizontalOptions="End"
                    HorizontalTextAlignment="End"
                    Text="{Binding Total, StringFormat='{0:C}'}" 
                    Style="{StaticResource Title1}"
                    TextColor="MediumSeaGreen"/>

            </Grid>

            <CollectionView 
                Grid.Row="1"
                ItemsSource="{Binding ListGroup}"
                IsGrouped="True"
                SelectionMode="Single"
                SelectedItem="{Binding SelectedItem}"
                SelectionChangedCommand="{Binding OpenItemCommand, Source={RelativeSource AncestorType={x:Type pageModels:SpentListPageModel}}, x:DataType=pageModels:SpentListPageModel}"
                SelectionChangedCommandParameter="{Binding SelectedItem}">

                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="models:SpentGroup">

                        <StackLayout>
                            <Label
                                Margin="20"
                                Style="{StaticResource Body3}"
                                Text="{Binding Name}"/>
                        </StackLayout>

                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Spent">


                        <VerticalStackLayout 
                            Spacing="20"
                            Padding="20,0,20,0">

                            <Grid 
                                ColumnDefinitions="*,Auto"
                                VerticalOptions="Center">

                                <Label 
                                    Text="{Binding Name}"/>

                                <Label 
                                    Grid.Column="1"
                                    Text="{Binding Value,StringFormat='{0:C}'}"
                                    Style="{StaticResource Body1Strong}"/>

                            </Grid>

                            <BoxView
                                Color="{StaticResource Gray100}"
                                WidthRequest="400"
                                HeightRequest="1"/>

                        </VerticalStackLayout>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </Grid>


        <controls:AddButton
            Command="{Binding AddItemCommand}"
            SemanticProperties.Description="Add" 
            ToolTipProperties.Text="Add" />

    </Grid>
</ContentPage>